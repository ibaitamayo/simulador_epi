if (!any(vals == year_target, na.rm = TRUE)) {
yrs <- sort(unique(vals[vals >= 1950 & vals <= 2100]))
stop("No rows for target year ", year_target, ". Available plausible years include: ",
paste(head(yrs, 80), collapse = ", "), call. = FALSE)
}
best
}
pick_country_col <- function(raw) {
cols <- names(raw)
candidates <- cols[grepl("country|area|location|region", cols, ignore.case = TRUE) &
!grepl("code|locid|iso|sdmx|parent|type|index|note", cols, ignore.case = TRUE)]
# In WPP F02_1 this is usually region_subregion_country_or_area.
if (length(candidates) == 0) candidates <- cols[vapply(raw, is.character, logical(1))]
scores <- vapply(candidates, function(cc) {
vals <- as.character(raw[[cc]])
vals <- vals[!is.na(vals) & nzchar(vals)]
if (length(vals) == 0) return(-Inf)
nonnum <- mean(is.na(suppressWarnings(as.numeric(vals))))
uniq <- length(unique(vals))
country_hits <- sum(vals %in% c("Norway", "United States of America", "China", "India", "Brazil", "South Africa"))
name_score <- ifelse(grepl("country|area", cc), 10, ifelse(grepl("location|region", cc), 5, 0))
nonnum * 20 + min(uniq, 300) / 30 + 20 * country_hits + name_score
}, numeric(1))
candidates[which.max(scores)]
}
normalize_age_col_name <- function(nm) {
nm <- clean_names(nm)
nm <- sub("^x", "", nm)       # readxl may prefix numeric names with x
nm <- sub("_years$", "", nm)
nm <- sub("_year$", "", nm)
nm <- sub("_yrs$", "", nm)
nm <- sub("_plus$", "", nm)
nm
}
parse_age_start_from_col <- function(nm) {
z <- normalize_age_col_name(nm)
# examples: 0_4, 5_9, 100, 100_plus
if (!grepl("^[0-9]+(_[0-9]+)?$", z)) return(NA_integer_)
suppressWarnings(as.integer(sub("^([0-9]+).*$", "\\1", z)))
}
find_wide_age_cols <- function(raw) {
starts <- vapply(names(raw), parse_age_start_from_col, integer(1))
age_cols <- names(raw)[!is.na(starts) & starts >= 0 & starts <= 130]
# Require at least several quinquennial columns to treat as wide layout.
if (length(age_cols) >= 10) {
return(data.frame(col = age_cols, age_start = starts[match(age_cols, names(raw))], stringsAsFactors = FALSE))
}
data.frame(col = character(0), age_start = integer(0), stringsAsFactors = FALSE)
}
collapse_group <- function(age_start) {
ifelse(age_start < 10, "0-9",
ifelse(age_start < 20, "10-19",
ifelse(age_start < 40, "20-39",
ifelse(age_start < 60, "40-59",
ifelse(age_start < 80, "60-79", "80+")))))
}
age_groups <- c("0-9", "10-19", "20-39", "40-59", "60-79", "80+")
