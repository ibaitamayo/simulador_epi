"Russia" = "Russian Federation",
"Iran" = "Iran (Islamic Republic of)",
"Vietnam" = "Viet Nam",
"South Korea" = "Republic of Korea",
"Turkey" = "Türkiye"
)
lookup <- tibble::tibble(
country = simulator_countries,
wpp_country = dplyr::recode(simulator_countries, !!!name_map)
)
dat_year <- dat %>%
mutate(Year = as.integer(.data[[year_col]])) %>%
filter(Year == target_year) %>%
select(all_of(c(country_col, year_col, age_cols_required))) %>%
rename(wpp_country = all_of(country_col))
out <- lookup %>%
left_join(dat_year, by = "wpp_country")
missing_countries <- out %>% filter(is.na(.data[[year_col]])) %>% pull(country)
if (length(missing_countries) > 0) {
examples <- sort(unique(dat_year$wpp_country))
stop(paste0(
