enable_evolution = FALSE,
starting_country = "South Africa",
air_travel_scenario = "reference",
import_establishment_probability = 1.00,
infectiousness_profile = "early",
rng_seed = 20211124,
progress_callback = NULL,
neutral_age_weights = FALSE,
age_cfr_scale = 1,
containment_schedule = NULL,
dynamic_adaptive_saturation = TRUE,
