"Examples of available WPP names: ", paste(utils::head(examples, 50), collapse = "; ")
), call. = FALSE)
}
# Convert thousands to proportions. Absolute scale cancels out after normalization.
out <- out %>%
mutate(across(all_of(age_cols_required), as.numeric)) %>%
transmute(
country,
age_0_9 = `0-4` + `5-9`,
age_10_19 = `10-14` + `15-19`,
age_20_39 = `20-24` + `25-29` + `30-34` + `35-39`,
age_40_59 = `40-44` + `45-49` + `50-54` + `55-59`,
age_60_79 = `60-64` + `65-69` + `70-74` + `75-79`,
age_80_plus = `80-84` + `85-89` + `90-94` + `95-99` + `100+`,
source_year = target_year,
source_sheet = sheet_to_use,
source = "UN_WPP_2024_population_by_5year_age_groups_both_sexes"
) %>%
rowwise() %>%
mutate(total = sum(c_across(starts_with("age_")), na.rm = TRUE)) %>%
ungroup() %>%
mutate(across(starts_with("age_"), ~ .x / total)) %>%
select(-total)
# Validate row sums
row_sums <- out %>% select(starts_with("age_")) %>% rowSums(na.rm = TRUE)
if (any(abs(row_sums - 1) > 1e-8)) {
stop("Age distribution rows do not sum to 1 after normalization.", call. = FALSE)
}
