}
simulator_countries <- c(
"Argentina", "Australia", "Austria", "Belgium", "Brazil", "Canada", "Chile", "China",
"Colombia", "Denmark", "Egypt", "Finland", "France", "Germany", "Greece", "India",
"Indonesia", "Iran", "Iraq", "Ireland", "Israel", "Italy", "Japan", "Kenya",
"Malaysia", "Mexico", "Morocco", "Netherlands", "New Zealand", "Nigeria", "Norway",
"Pakistan", "Peru", "Philippines", "Poland", "Portugal", "Russia", "Saudi Arabia",
"Singapore", "South Africa", "South Korea", "Spain", "Sweden", "Switzerland", "Thailand",
