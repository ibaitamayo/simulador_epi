"run_simulation_age_adjusted", "WORLD_POPULATION", "calculate_metrics",
"make_country_age_distribution", "COUNTRIES_LIST"
)
missing <- needed[!vapply(needed, exists, logical(1), envir = env, inherits = TRUE)]
if (length(missing) > 0) stop("Missing required objects after sourcing app: ", paste(missing, collapse = ", "), call. = FALSE)
