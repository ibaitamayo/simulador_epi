clean_names <- function(x) {
x <- gsub("\\s+", "_", x)
x <- gsub("[^A-Za-z0-9_]+", "_", x)
x <- gsub("_+", "_", x)
tolower(gsub("^_|_$", "", x))
}
read_wpp_table <- function(input_file) {
ext <- tolower(tools::file_ext(input_file))
message("Reading: ", input_file)
if (ext %in% c("xlsx", "xls")) {
if (!requireNamespace("readxl", quietly = TRUE)) {
stop("Package 'readxl' is required. Install it with install.packages('readxl').", call. = FALSE)
}
sheets <- readxl::excel_sheets(input_file)
sheet_order <- unique(c(sheets[grepl("population|estimate|medium|data|both", sheets, ignore.case = TRUE)], sheets))
for (sh in sheet_order) {
for (skip in 0:35) {
tmp <- tryCatch(
as.data.frame(readxl::read_excel(input_file, sheet = sh, skip = skip), stringsAsFactors = FALSE),
error = function(e) NULL
)
if (is.null(tmp) || ncol(tmp) < 10 || nrow(tmp) == 0) next
nm_orig <- names(tmp)
nm <- clean_names(nm_orig)
names(tmp) <- nm
has_country <- any(grepl("country|area|location|region", nm, ignore.case = TRUE))
has_year <- any(grepl("^year$|time|period", nm, ignore.case = TRUE))
has_age_cols <- any(grepl("^x?0_4$|^0_4$|^x?5_9$|^5_9$|^x?80_84$|^80_84$|^x?100$|^100$", nm)) ||
any(grepl("^x?[0-9]+_[0-9]+$", nm))
has_pop_long <- any(grepl("pop|population|value", nm, ignore.case = TRUE)) && any(grepl("age", nm, ignore.case = TRUE))
if (has_country && has_year && (has_age_cols || has_pop_long)) {
message("Using sheet '", sh, "' with skip=", skip)
message("First columns: ", paste(head(nm, 20), collapse = ", "))
return(tmp)
}
}
}
stop("Could not find the WPP data table/header. Check the workbook and sheet format.", call. = FALSE)
}
raw <- read.csv(input_file, stringsAsFactors = FALSE, check.names = FALSE)
names(raw) <- clean_names(names(raw))
raw
}
raw <- read_wpp_table(input_file)
pick_year_col <- function(raw, year_target) {
cols <- names(raw)
candidates <- cols[grepl("^year$|time|period", cols, ignore.case = TRUE)]
if (length(candidates) == 0) candidates <- cols
scores <- vapply(candidates, function(cc) {
vals <- suppressWarnings(as.integer(raw[[cc]]))
vals <- vals[!is.na(vals)]
if (length(vals) == 0) return(-Inf)
in_range <- mean(vals >= 1950 & vals <= 2100)
has_target <- any(vals == year_target)
name_score <- ifelse(cc == "year", 10, ifelse(grepl("year|time|period", cc), 5, 0))
if (grepl("code|locid|location|iso|sdmx|index|parent", cc)) name_score <- name_score - 20
100 * as.numeric(has_target) + 20 * in_range + name_score
}, numeric(1))
best <- candidates[which.max(scores)]
vals <- suppressWarnings(as.integer(raw[[best]]))
if (!any(vals == year_target, na.rm = TRUE)) {
yrs <- sort(unique(vals[vals >= 1950 & vals <= 2100]))
stop("No rows for target year ", year_target, ". Available plausible years include: ",
paste(head(yrs, 80), collapse = ", "), call. = FALSE)
}
best
}
