# Source the app without launching shinyApp().
source_app_without_launch <- function(file, envir) {
txt <- readLines(file, warn = FALSE)
txt <- paste(txt, collapse = "\n")
txt <- sub("shinyApp\\s*\\(\\s*ui\\s*=\\s*ui\\s*,\\s*server\\s*=\\s*server\\s*\\)\\s*$", "", txt)
tmp <- tempfile(fileext = ".R")
writeLines(txt, tmp)
sys.source(tmp, envir = envir)
}
# Extract a nested function assignment from the app source and evaluate it in env.
# This is needed because run_simulation_age_adjusted() is defined inside server()
# in the Shiny app but only depends on globally defined helpers/constants.
extract_function_assignment <- function(file, assignment_name) {
lines <- readLines(file, warn = FALSE)
start <- grep(paste0("^\\s*", assignment_name, "\\s*<-\\s*function\\s*\\("), lines)[1]
if (is.na(start)) stop("Could not find function assignment: ", assignment_name, call. = FALSE)
out <- character()
depth <- 0L
started <- FALSE
for (i in seq(from = start, to = length(lines))) {
line <- lines[[i]]
out <- c(out, line)
# Approximate brace balance; sufficient for the simulator source.
opens <- gregexpr("\\{", line, fixed = FALSE)[[1]]
closes <- gregexpr("\\}", line, fixed = FALSE)[[1]]
n_open <- if (opens[1] == -1) 0L else length(opens)
n_close <- if (closes[1] == -1) 0L else length(closes)
if (n_open > 0) started <- TRUE
depth <- depth + n_open - n_close
if (started && depth == 0L) break
}
paste(out, collapse = "\n")
}
env <- new.env(parent = globalenv())
source_app_without_launch(basename(app_file), env)
fn_txt <- extract_function_assignment(basename(app_file), "run_simulation_age_adjusted")
eval(parse(text = fn_txt), envir = env)
